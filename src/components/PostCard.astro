---
interface Props {
  id: string;
  title: string;
  pubDate: Date;
  description: string;
}

const { id, title, pubDate, description } = Astro.props;
---

<article class="post-card">
  <a href={`/posts/${id}/`}>
    <h2>{title}</h2>
    <time datetime={pubDate.toISOString()}>
      {
        pubDate.toLocaleDateString("en-US", {
          year: "numeric",
          month: "long",
          day: "numeric",
        })
      }
    </time>
    <p>{description}</p>
  </a>
</article>

<style>
  .post-card {
    margin-bottom: 1.5rem;
  }

  .post-card a {
    display: block;
    padding: 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    color: var(--color-text);
    transition: border-color 0.2s;
  }

  .post-card a:hover {
    border-color: var(--color-link);
    text-decoration: none;
  }

  h2 {
    margin-bottom: 0.25rem;
    font-size: 1.25rem;
  }

  time {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  p {
    margin-top: 0.5rem;
    color: var(--color-text-muted);
    font-size: 0.9375rem;
  }
</style>
