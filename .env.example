# Bluesky (AT Protocol — use app password, not main password)
BLUESKY_SERVICE=https://bsky.social
BLUESKY_IDENTIFIER=your-handle.bsky.social
BLUESKY_PASSWORD=your-app-password

# Mastodon
MASTODON_URL=https://mastodon.social
MASTODON_ACCESS_TOKEN=

# LinkedIn (OAuth 2.0 — token expires every 60 days)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_ID=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Medium
MEDIUM_INTEGRATION_TOKEN=

# Dev.to
DEVTO_API_KEY=

# Substack (via SMTP — posts arrive as drafts)
SUBSTACK_SMTP_HOST=smtp.gmail.com
SUBSTACK_SMTP_PORT=587
SUBSTACK_SMTP_USER=
SUBSTACK_SMTP_PASSWORD=
SUBSTACK_FROM_ADDRESS=
SUBSTACK_TO_ADDRESS=

# Queue polling interval (milliseconds)
POLL_INTERVAL_MS=60000
